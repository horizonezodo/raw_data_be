  <bpmn:process id="CRM.201.01" isExecutable="true" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="Event_11jlagw" camunda:asyncAfter="true">
      <bpmn:extensionElements>
        <camunda:executionListener delegateExpression="${afterStartListener}" event="start" />
        <camunda:properties>
          <camunda:property name="is_fullscreen" value="1" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_0kelpuj</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="CRM.201.01.01" name="Phê duyệt điều chỉnh khách hàng" camunda:asyncBefore="true" camunda:formKey="/crm/customer/adjust/approve" camunda:candidateGroups="KS_QHKH">
      <bpmn:extensionElements>
        <camunda:taskListener delegateExpression="${taskCreateListener}" event="create" />
        <camunda:properties>
          <camunda:property name="path_complete" value="/api-crm/api/bpm-client/task/submit" />
          <camunda:property name="form_action" value="APPROVE,REJECT" />
        </camunda:properties>
        <camunda:taskListener delegateExpression="${taskAssignmentListener}" event="assignment" />
        <camunda:taskListener delegateExpression="${taskCompleteListener}" event="complete" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0kelpuj</bpmn:incoming>
      <bpmn:incoming>send_approve</bpmn:incoming>
      <bpmn:incoming>Flow_Error_Approve</bpmn:incoming>
      <bpmn:outgoing>Flow_1lw0u0g</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_1frxw4g">
      <bpmn:incoming>Flow_10ed1qx</bpmn:incoming>
      <bpmn:outgoing>approve</bpmn:outgoing>
      <bpmn:outgoing>reject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Activity_1gwnvqw" name="Cập nhật thông tin kết thúc luồng" camunda:type="external" camunda:topic="CRM_201_EXTERNAL_TASK_END_PROCESS">
      <bpmn:incoming>approve</bpmn:incoming>
      <bpmn:incoming>cancel</bpmn:incoming>
      <bpmn:outgoing>Flow_0zq9o49</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_1y9cs3l" name="Thông báo email từ chối phê duyệt" camunda:delegateExpression="${sendEmailListener}">
      <bpmn:incoming>reject</bpmn:incoming>
      <bpmn:outgoing>Flow_06q2qjp</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="CRM.201.01.02" name="Chỉnh sửa thông tin khách hàng" camunda:formKey="/crm/customer/adjust/edit" camunda:candidateGroups="CB_QHKH">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="path_complete" value="/api-crm/api/bpm-client/task/submit" />

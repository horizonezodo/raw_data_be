<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1767842418279-1" author="dinht">
        <createTable tableName="ibm_cfg_dep_product">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_ibm_cfg_dep_product"/>
            </column>
            <column name="created_date" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="approved_date" type="DATETIME"/>
            <column name="approved_by" type="VARCHAR(64)"/>
            <column name="modified_date" type="DATETIME"/>
            <column name="modified_by" type="VARCHAR(64)"/>
            <column name="is_delete" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(512)"/>
            <column name="record_status" type="VARCHAR(64)"/>
            <column name="org_code" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="currency_code" type="VARCHAR(4)">
                <constraints nullable="false"/>
            </column>
            <column name="ibm_dep_product_code" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>
            <column name="ibm_dep_product_name" type="VARCHAR(512)">
                <constraints nullable="false"/>
            </column>
            <column name="ibm_dep_product_type_code" type="VARCHAR(128)"/>
            <column name="interest_payment_method" type="VARCHAR(64)"/>
            <column name="acc_class_code" type="VARCHAR(128)"/>
            <column name="acc_structure_code" type="VARCHAR(64)"/>
            <column name="term_value" type="INT"/>
            <column name="term_unit" type="VARCHAR(32)"/>
            <column name="interest_rate_code" type="VARCHAR(64)"/>
            <column name="early_interest_code" type="VARCHAR(64)"/>
            <column name="effective_date" type="DATETIME"/>
            <column name="expiry_date" type="DATETIME"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
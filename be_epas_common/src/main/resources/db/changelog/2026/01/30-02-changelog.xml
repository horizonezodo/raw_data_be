<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1769768508842-1" author="manhn">
        <createTable tableName="com_cfg_permission">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_com_cfg_permission"/>
            </column>
            <column name="created_date" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="approved_date" type="DATETIME"/>
            <column name="approved_by" type="VARCHAR(64)"/>
            <column name="modified_date" type="DATETIME"/>
            <column name="modified_by" type="VARCHAR(64)"/>
            <column name="is_delete" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(512)"/>
            <column name="code" type="VARCHAR(255)"/>
            <column name="name" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>
    <changeSet id="1769768508842-2" author="manhn">
        <createTable tableName="com_cfg_permission_map">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_com_cfg_permission_map"/>
            </column>
            <column name="created_date" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="approved_date" type="DATETIME"/>
            <column name="approved_by" type="VARCHAR(64)"/>
            <column name="modified_date" type="DATETIME"/>
            <column name="modified_by" type="VARCHAR(64)"/>
            <column name="is_delete" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(512)"/>
            <column name="group_name" type="VARCHAR(255)"/>
            <column name="user_id" type="VARCHAR(255)"/>
            <column name="permission_code" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
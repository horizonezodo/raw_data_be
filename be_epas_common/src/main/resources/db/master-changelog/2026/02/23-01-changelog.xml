<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <changeSet id="1771837326190-1" author="manhn">
        <!-- Nếu bảng đã tồn tại thì bỏ qua (MARK_RAN) để tránh ORA-00955 -->
        <preConditions onFail="MARK_RAN" onError="HALT">
            <not>
                <tableExists tableName="COM_CFG_TENANT"/>
            </not>
        </preConditions>

        <createTable tableName="COM_CFG_TENANT">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_com_cfg_tenant"/>
            </column>
            <column name="created_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="approved_date" type="TIMESTAMP"/>
            <column name="approved_by" type="VARCHAR(64)"/>
            <column name="modified_date" type="TIMESTAMP"/>
            <column name="modified_by" type="VARCHAR(64)"/>
            <column name="is_delete" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(512)"/>
            <column name="tenant_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="db_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="jdbc_url" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="username" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="PASSWORD" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="driver_class" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="VARCHAR(1)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>
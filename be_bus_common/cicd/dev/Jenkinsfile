pipeline {
    agent any
    environment {
        dockerImage = ''
        containerName = 'epas-bus-common-be'
        ENV = 'dev'
        PORT = '8306'
        JAVA_OPTS = '-Xms256m -Xmx512m'
    }
    tools {
        maven 'Maven'
    }

    stages {
        stage('Clone source') {
            steps {
                echo 'Cloning repository...'
                checkout scm
            }
        }

        stage('Build Maven') {
            steps {
                echo 'Building Spring Boot application...'
                sh 'mkdir -p $HOME/.m2'
                sh 'mvn clean package -DskipTests --settings .mvn/settings.xml -Dmaven.repo.local=$HOME/.m2/repository'
            }
        }

        stage('Build and Deploy') {
            steps {
                script {
                    echo 'Stopping and removing old container if exists...'
                    sh '''
                        if docker ps -a --filter "name=${ENV}-${containerName}" | grep -q ${ENV}-${containerName}; then
                            docker stop ${ENV}-${containerName} || true
                            docker rm ${ENV}-${containerName} || true
                        fi
                    '''
                    echo 'Removing old Docker image if exists...'
                    sh '''
                        if docker images -q ${containerName}:${ENV}; then
                            docker rmi ${containerName}:${ENV} || true
                        fi
                    '''
                    echo 'Building Docker image...'
                    dockerImage = docker.build("${containerName}:${ENV}", "--rm -f cicd/dev/Dockerfile .")
                    echo 'Starting Docker container...'
                    sh '''
                        docker run -d \
                        --name ${ENV}-${containerName} \
                        -e SPRING_PROFILES_ACTIVE=${ENV} \
                        -e JAVA_OPTS="${JAVA_OPTS}" \
                        -p ${PORT}:8306 \
                        ${containerName}:${ENV}
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline executed successfully!'
        }
        failure {
            echo 'Pipeline execution failed!'
        }
        always {
            cleanWs()
        }
    }
}

  <bpmn:process id="FAC.200.01" isExecutable="true" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="StartEvent_1" name="Bắt đầu" camunda:asyncAfter="true">
      <bpmn:extensionElements>
        <camunda:executionListener delegateExpression="${afterStartListener}" event="start" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_0oabjg9</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Activity_0tfpi06" name="Cập nhật trạng thái bản ghi" camunda:type="external" camunda:topic="FAC_200_TASK_APPROVE">

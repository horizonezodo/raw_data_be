<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1770006615302-1" author="Hoang Hiep">
        <createTable tableName="fac_cfg_acct_process">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_fac_cfg_acct_process"/>
            </column>
            <column name="created_date" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="approved_date" type="DATETIME"/>
            <column name="approved_by" type="VARCHAR(64)"/>
            <column name="modified_date" type="DATETIME"/>
            <column name="modified_by" type="VARCHAR(64)"/>
            <column name="is_delete" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(512)"/>
            <column name="org_code" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="acct_process_code" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="process_type_code" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>
            <column name="process_type_name" type="VARCHAR(256)">
                <constraints nullable="false"/>
            </column>
            <column name="module_code" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="record_status" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
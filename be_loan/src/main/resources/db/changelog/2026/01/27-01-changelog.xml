            </column>
            <column name="interest_rate_name" type="VARCHAR(256)">
                <constraints nullable="false"/>
            </column>
            <column name="interest_rate_type" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="apply_type" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="business_status" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="record_status" type="VARCHAR(64)"/>
            <column name="is_active" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>